<Window x:Class="Azure.PIM.Tray.Windows.ManageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Azure.PIM.Tray.Windows"
        Title="PIM Request Manager &#x2014; Settings"
        Width="960" Height="500"
        ResizeMode="CanResize" MinWidth="860" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">
    <Window.Resources>
        <local:NullToBoolTextConverter x:Key="NullToBoolText"/>
        <local:NullToColorConverter   x:Key="NullToColor"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TreeView Grid.Row="0" x:Name="TenantTree" Margin="0,0,0,8"
                  SelectedItemChanged="TenantTree_SelectedItemChanged"
                  TreeViewItem.Expanded="TenantTree_ItemExpanded">
            <TreeView.Resources>
                <!-- Tenant node -->
                <HierarchicalDataTemplate DataType="{x:Type local:TenantTreeNode}"
                                          ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Email}" Foreground="#666" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding PermissionsStatus}" Foreground="{Binding PermissionsColor}"
                                   Margin="12,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                </HierarchicalDataTemplate>

                <!-- Subscription node -->
                <DataTemplate DataType="{x:Type local:SubscriptionTreeNode}">
                    <CheckBox IsChecked="{Binding IsIncluded, Mode=TwoWay}"
                              Margin="2,1"
                              Checked="Subscription_Toggled"
                              Unchecked="Subscription_Toggled">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding IdDisplay}" Foreground="#999" Margin="8,0,0,0"
                                       VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                    </CheckBox>
                </DataTemplate>

                <!-- Loading placeholder -->
                <DataTemplate DataType="{x:Type local:LoadingTreeNode}">
                    <TextBlock Text="{Binding Text}" Foreground="#888" FontStyle="Italic" Margin="2,1"/>
                </DataTemplate>
            </TreeView.Resources>
        </TreeView>

        <Expander Grid.Row="1" x:Name="ExpanderAdd"
                  Header="Add tenant connection"
                  IsExpanded="False"
                  Margin="0,0,0,8">
            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,6,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Tenant ID:"
                               VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtTenantId"
                               Padding="4,3" Margin="0,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Email:"
                               VerticalAlignment="Center" Margin="0,4"/>
                    <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TxtEmail"
                               Padding="4,3" Margin="0,4"/>

                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtAddStatus"
                               Foreground="#CC0000" TextWrapping="Wrap"
                               Margin="0,4" Visibility="Collapsed"/>

                    <StackPanel Grid.Row="3" Grid.Column="1"
                                Orientation="Horizontal" Margin="0,6,0,0">
                        <Button x:Name="BtnConnect" Content="Connect &amp; Discover"
                                Style="{StaticResource PrimaryButton}"
                                Click="Connect_Click"/>
                        <TextBlock x:Name="TxtConnecting"
                                   Text="Opening browser..." VerticalAlignment="Center"
                                   Margin="10,0,0,0" Foreground="#666"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Expander>

        <Grid Grid.Row="2">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                <TextBlock x:Name="TxtVersion"
                           VerticalAlignment="Center"
                           Foreground="#0066CC" Cursor="Hand" FontSize="11"
                           MouseLeftButtonUp="Version_Click"
                           ToolTip="Check for updates">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="TextDecorations" Value="Underline"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button x:Name="BtnUpdateRestart"
                        Content="Update &amp; Restart"
                        Margin="8,0,0,0" Padding="10,3"
                        FontSize="11" Cursor="Hand"
                        Visibility="Collapsed"
                        Click="UpdateRestart_Click"
                        ToolTip="Apply the downloaded update and restart the app">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#0088DD"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnFixPermissions"
                        Content="Fix Permissions"
                        Margin="0,0,8,0" Padding="12,5"
                        ToolTip="Adds all required API permissions and grants admin consent. Requires Global Administrator."
                        Click="FixPermissions_Click"/>
                <Button x:Name="BtnSignIn"
                        Content="Sign In selected"
                        Margin="0,0,8,0" Padding="12,5"
                        ToolTip="Opens a browser to sign in and populate the token cache for the selected tenant."
                        Click="SignIn_Click"/>
                <Button x:Name="BtnRemoveSelected"
                        Content="Remove selected"
                        Margin="0,0,8,0" Padding="12,5"
                        Click="Remove_Click"/>
                <Button Content="Close"
                        Style="{StaticResource PrimaryButton}"
                        Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
