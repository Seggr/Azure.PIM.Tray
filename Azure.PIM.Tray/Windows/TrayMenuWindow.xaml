<Window x:Class="Azure.PIM.Tray.Windows.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Deactivated="Window_Deactivated">
    <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
            CornerRadius="4" Padding="2">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="3" Opacity="0.3" BlurRadius="8"/>
        </Border.Effect>
        <StackPanel x:Name="MenuPanel" MinWidth="240"/>
    </Border>
</Window>
