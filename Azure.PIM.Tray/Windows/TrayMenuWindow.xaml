<Window x:Class="Azure.PIM.Tray.Windows.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="False" Background="White"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Deactivated="Window_Deactivated">
    <Border Background="White" BorderBrush="#BBBBBB" BorderThickness="1"
            CornerRadius="4" Padding="2" SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="ScrollUpArrow" Grid.Row="0" Visibility="Collapsed"
                    Background="White" Padding="0,3" Cursor="Hand">
                <TextBlock Text="&#x25B2;" FontSize="8" Foreground="#999999"
                           HorizontalAlignment="Center"/>
            </Border>

            <ScrollViewer x:Name="MenuScroll" Grid.Row="1"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="MenuPanel" MinWidth="240"/>
            </ScrollViewer>

            <Border x:Name="ScrollDownArrow" Grid.Row="2" Visibility="Collapsed"
                    Background="White" Padding="0,3" Cursor="Hand">
                <TextBlock Text="&#x25BC;" FontSize="8" Foreground="#999999"
                           HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
