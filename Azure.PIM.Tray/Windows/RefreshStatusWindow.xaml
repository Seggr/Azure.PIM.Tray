<Window x:Class="Azure.PIM.Tray.Windows.RefreshStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Refresh Status"
        Width="420" SizeToContent="Height"
        MinHeight="120"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Refresh status per tenant:"
                   FontWeight="SemiBold" Margin="0,0,0,10"/>

        <ItemsControl Grid.Row="1" x:Name="StatusList" Margin="0,0,0,12">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#D0D8EE" BorderThickness="1"
                            CornerRadius="4" Padding="10,6" Margin="0,3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding TenantName}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Status}"
                                       Foreground="#555"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="200"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Grid.Row="2" Content="Close"
                HorizontalAlignment="Right"
                Padding="14,5"
                Click="Close_Click"/>
    </Grid>
</Window>
