<Window x:Class="Azure.PIM.Tray.Windows.ActivateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Activate Role"
        Width="460" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Role"  Style="{StaticResource DetailLabel}"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtRole"
                           Style="{StaticResource DetailValue}" FontWeight="SemiBold"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Type"  Style="{StaticResource DetailLabel}"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtType" Style="{StaticResource DetailValue}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Scope" Style="{StaticResource DetailLabel}"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtScope" Style="{StaticResource DetailValue}"/>
            </Grid>
        </Border>

        <TextBlock Grid.Row="1" Text="Duration:" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <ComboBox x:Name="CboDuration" Width="140" SelectionChanged="CboDuration_Changed">
                <ComboBoxItem Content="30 minutes"  Tag="30"/>
                <ComboBoxItem Content="1 hour"      Tag="60"  IsSelected="True"/>
                <ComboBoxItem Content="2 hours"     Tag="120"/>
                <ComboBoxItem Content="4 hours"     Tag="240"/>
                <ComboBoxItem Content="8 hours"     Tag="480"/>
                <ComboBoxItem Content="Custom..."   Tag="0"/>
            </ComboBox>
            <TextBox x:Name="TxtCustomMinutes"
                     Width="80" Margin="8,0,0,0" Padding="4,2"
                     VerticalContentAlignment="Center"
                     Visibility="Collapsed"
                     Text="60"/>
            <TextBlock Text=" minutes" VerticalAlignment="Center"
                       x:Name="LblCustomUnit" Visibility="Collapsed"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="Justification:" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox   Grid.Row="4" x:Name="TxtJustification"
                   Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                   VerticalScrollBarVisibility="Auto"
                   Margin="0,0,0,14"
                   VerticalContentAlignment="Top"
                   Padding="4"/>

        <TextBlock Grid.Row="5" x:Name="TxtError"
                   Foreground="Red" TextWrapping="Wrap"
                   Visibility="Collapsed" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"  Style="{StaticResource CancelButton}"
                    Margin="0,0,8,0"  Click="Cancel_Click"/>
            <Button x:Name="BtnActivate" Content="Activate"
                    Style="{StaticResource PrimaryButton}"
                    Click="Activate_Click"/>
        </StackPanel>
    </Grid>
</Window>
