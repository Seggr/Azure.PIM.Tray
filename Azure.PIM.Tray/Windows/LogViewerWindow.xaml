<Window x:Class="Azure.PIM.Tray.Windows.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log Viewer"
        Width="820" Height="520"
        MinWidth="560" MinHeight="300"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Show:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox  Grid.Column="1" x:Name="CboLevel" Width="110"
                       SelectedIndex="0" SelectionChanged="CboLevel_Changed">
                <ComboBoxItem Content="All levels"/>
                <ComboBoxItem Content="Debug +"/>
                <ComboBoxItem Content="Info +"/>
                <ComboBoxItem Content="Warning +"/>
                <ComboBoxItem Content="Error only"/>
            </ComboBox>

            <TextBlock Grid.Column="2" Text="Source:" VerticalAlignment="Center" Margin="16,0,8,0"/>
            <TextBox   Grid.Column="3" x:Name="TxtSourceFilter" Width="160" Padding="4,2"
                       VerticalContentAlignment="Center"
                       ToolTip="Filter by source (partial match, case-insensitive)"
                       TextChanged="Filter_Changed"/>

            <TextBlock Grid.Column="4" x:Name="CountLabel"
                       VerticalAlignment="Center" Foreground="#555"
                       HorizontalAlignment="Right" Margin="12,0,0,0"/>

            <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="12,0,0,0">
                <ComboBox x:Name="CboMinLevel" Width="140"
                          ToolTip="Minimum level written to the log (lower levels are discarded)"
                          SelectionChanged="CboMinLevel_Changed">
                    <ComboBoxItem Content="Log: Debug +" Tag="0"/>
                    <ComboBoxItem Content="Log: Info +" Tag="1"/>
                    <ComboBoxItem Content="Log: Warning +" Tag="2"/>
                    <ComboBoxItem Content="Log: Error only" Tag="3"/>
                </ComboBox>
                <CheckBox x:Name="ChkLogToDisk"
                          Content="Log to disk"
                          VerticalAlignment="Center"
                          Margin="14,0,0,0"
                          ToolTip="Write log entries to rolling files in the AppData log folder (up to 3 × 10 MB)"
                          Checked="ChkLogToDisk_Changed"
                          Unchecked="ChkLogToDisk_Changed"/>
            </StackPanel>
        </Grid>

        <ListView Grid.Row="1"
                  x:Name="LogList"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.ScrollUnit="Pixel">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Copy Entry" Click="CopyItem_Click"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Level}" Value="Error">
                            <Setter Property="Background" Value="#FFF0F0"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Level}" Value="Warning">
                            <Setter Property="Background" Value="#FFFDF0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Time" Width="95">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TimestampDisplay}"
                                           FontFamily="Consolas" FontSize="11"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Level" Width="72">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Level}"
                                           FontWeight="SemiBold" FontSize="11"
                                           Foreground="{Binding LevelColor}"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Source" Width="180">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Source}"
                                           Foreground="#004499"
                                           FontWeight="SemiBold" FontSize="11"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Source}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Message" Width="400">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Message}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BtnOpenLogDir"
                    Content="Open Log Folder"
                    Padding="14,5" Margin="0,0,8,0"
                    IsEnabled="False"
                    ToolTip="Open the folder containing the log files in Explorer"
                    Click="OpenLogDir_Click"/>
            <Button Content="Clear"
                    Padding="14,5" Margin="0,0,8,0"
                    Click="ClearLogs_Click"/>
            <Button Content="Copy All"
                    Padding="14,5" Margin="0,0,8,0"
                    Click="CopyAll_Click"/>
            <Button Content="Close"
                    Padding="14,5"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
